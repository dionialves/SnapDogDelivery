# Exemplo de configuração de produção
# Copiar para application-prod.properties e definir as variáveis de ambiente:
#
#   DB_URL      — ex: jdbc:postgresql://host:5432/snapdogdelivery
#   DB_USERNAME — ex: postgres
#   DB_PASSWORD — senha do banco de dados
#
# Ativar o profile de produção com:
#   java -jar app.jar --spring.profiles.active=prod
# ou via variável de ambiente:
#   SPRING_PROFILES_ACTIVE=prod

spring.jpa.database=postgresql
spring.jpa.show-sql=false
spring.jpa.hibernate.ddl-auto=validate

spring.database.driverClassName=org.postgresql.Driver
spring.datasource.platform=postgres
spring.datasource.url=${DB_URL}
spring.datasource.username=${DB_USERNAME}
spring.datasource.password=${DB_PASSWORD}
